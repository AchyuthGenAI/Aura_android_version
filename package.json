{
  "name": "aura-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "Persist Ventures",
  "description": "Windows-first Aura desktop wrapper for OpenClaw.",
  "main": "dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup --watch",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 file:dist/main.cjs && node scripts/dev-electron.cjs",
    "dev:electron:debug": "wait-on http-get://127.0.0.1:5173 file:dist/main.cjs && AURA_OPEN_DEVTOOLS=1 node scripts/dev-electron.cjs",
    "build:openclaw": "cd vendor/openclaw && pnpm install && pnpm build",
    "build": "npm run build:openclaw && npm run build:main && npm run build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "generate:icons": "powershell -ExecutionPolicy Bypass -File .\\scripts\\generate-windows-icon.ps1",
    "prepackage": "cd vendor/openclaw && pnpm prune --prod || npm prune --production",
    "package:win": "npm run prepackage && npm run generate:icons && electron-builder --win nsis",
    "package:win:dir": "npm run prepackage && npm run generate:icons && electron-builder --win dir",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ai.persistventures.aura.desktop",
    "productName": "Aura Desktop",
    "icon": "icon.png",
    "files": [
      "dist/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "vendor/openclaw/openclaw.mjs",
        "to": "openclaw-src/openclaw.mjs"
      },
      {
        "from": "vendor/openclaw/package.json",
        "to": "openclaw-src/package.json"
      },
      {
        "from": "vendor/openclaw/dist",
        "to": "openclaw-src/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/openclaw/assets",
        "to": "openclaw-src/assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/openclaw/skills",
        "to": "openclaw-src/skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/openclaw/node_modules",
        "to": "openclaw-src/node_modules",
        "filter": [
          "**/*",
          "!.cache/**",
          "!.package-lock.json"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/@nut-tree-fork/**",
      "node_modules/koffi/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Aura Desktop"
    },
    "copyright": "Copyright (c) 2025 Persist Ventures",
    "publish": null
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.1",
    "electron": "^37.2.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "wait-on": "^8.0.1"
  }
}
