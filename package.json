{
  "name": "aura-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "Persist Ventures",
  "description": "Windows-first Aura desktop wrapper for OpenClaw.",
  "main": "dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup --watch",
    "dev:electron": "node scripts/dev-electron.cjs",
    "dev:electron:debug": "AURA_OPEN_DEVTOOLS=1 node scripts/dev-electron.cjs",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "stage:openclaw-runtime": "node --experimental-strip-types scripts/stage-openclaw-runtime.ts",
    "validate:openclaw-bundle": "node --experimental-strip-types scripts/validate-openclaw-bundle.ts",
    "generate:icons": "powershell -ExecutionPolicy Bypass -File .\\scripts\\generate-windows-icon.ps1",
    "generate:icons:mac": "node scripts/generate-macos-icon.mjs",
    "bootstrap:skills:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bootstrap-openclaw-skills.ps1",
    "smoke:packaged-runtime": "node --experimental-strip-types scripts/smoke-packaged-runtime.ts",
    "package:win": "npm run build && npm run generate:icons && npm run stage:openclaw-runtime && npm run validate:openclaw-bundle && electron-builder --win nsis --publish never",
    "package:win:dir": "npm run build && npm run generate:icons && npm run stage:openclaw-runtime && npm run validate:openclaw-bundle && electron-builder --win dir --publish never && npm run smoke:packaged-runtime",
    "package:win:portable": "npm run build && npm run generate:icons && npm run stage:openclaw-runtime && npm run validate:openclaw-bundle && electron-builder --win portable --publish never",
    "package:mac": "npm run build && npm run generate:icons:mac && npm run stage:openclaw-runtime && npm run validate:openclaw-bundle && electron-builder --mac dmg --universal --publish never",
    "package:mac:dir": "npm run build && npm run generate:icons:mac && npm run stage:openclaw-runtime && npm run validate:openclaw-bundle && electron-builder --mac dir --universal --publish never",
    "typecheck": "tsc --noEmit",
    "smoke:post-merge": "node --experimental-strip-types scripts/post-merge-smoke.ts",
    "test:automation:ws": "node scripts/test-automation-ws.cjs",
    "test:openclaw-protocol": "node scripts/test-openclaw-protocol.cjs",
    "eval:automation:ws": "node scripts/evaluate-automation-ws.cjs",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ai.persistventures.aura.desktop",
    "productName": "Aura Desktop",
    "icon": "icon.png",
    "files": [
      "dist/*.cjs",
      "dist/*.cjs.map",
      "dist/renderer/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist/installer-v6"
    },
    "extraResources": [
      {
        "from": "native-automation",
        "to": "native-automation",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/openclaw-runtime",
        "to": "openclaw-src",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Aura Desktop-${version}-mac.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "x64ArchFiles": "Contents/Resources/openclaw-src/node_modules/**/*"
    },
    "dmg": {
      "artifactName": "Aura Desktop-${version}-mac.${ext}",
      "title": "Aura Desktop ${version}",
      "internetEnabled": false
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    }
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.1",
    "cron": "^4.4.0",
    "dompurify": "^3.3.3",
    "firebase": "^12.12.0",
    "marked": "^17.0.4",
    "playwright-core": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.1",
    "electron": "^37.2.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "wait-on": "^8.0.1"
  }
}
