VITE_ENV=development
VITE_OPENCLAW_URL=https://your-openclaw-backend.example.com
AURA_GATEWAY_URL=ws://127.0.0.1:18789
AURA_GATEWAY_TOKEN=replace-with-your-gateway-token
AURA_DEFAULT_SESSION_KEY=agent:main:main
AURA_GATEWAY_AUTOSTART=0
GOOGLE_API_KEY=replace-with-your-gemini-key

VITE_LLM_PROVIDER=google
VITE_LLM_MODEL=gemini-2.0-flash
VITE_LLM_BASE_URL=https://generativelanguage.googleapis.com
VITE_LLM_API_KEY=replace-with-your-gemini-key
VITE_GEMINI_API_KEY=replace-with-your-gemini-key

VITE_FIREBASE_API_KEY=replace-with-your-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:replace-me
VITE_FIREBASE_MEASUREMENT_ID=G-REPLACE

VITE_DEEPGRAM_API_KEY=replace-with-your-key
VITE_DEEPGRAM_TTS_MODEL=aura-2-athena-en
VITE_VOICE_PROVIDER=deepgram

PLASMO_PUBLIC_GOOGLE_CLIENT_ID=replace-with-your-google-client-id

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
